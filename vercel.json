{
  "builds": [
    { "src": "**/*.php", "use": "vercel-php@0.7.4" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "portafolio/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/cliente/PaginaInicio.php" }
  ]
}
